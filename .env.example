# ─── Copy this file to .env and fill in the values ───────────────────────────
# Every service below has a FREE tier that needs NO credit card.

# --- LLM provider (pick ONE; LangChain swaps between them) --------------------
# Groq: https://console.groq.com  (free, no card) — recommended for speed
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_your_free_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini alternative: https://aistudio.google.com/apikey (free, no card)
# LLM_PROVIDER=gemini
GOOGLE_API_KEY=your_free_gemini_key_here
GEMINI_MODEL=gemini-2.0-flash

# --- Embeddings (runs locally in the Python container — no key, $0) -----------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Database (Neon free Postgres + pgvector) --------------------------------
# Local docker-compose default is below; replace with your Neon URL to deploy.
DATABASE_URL=postgresql://sentinel:sentinel@postgres:5432/sentinel

# --- Vector store: "pgvector" (Neon) or "faiss" (in-memory, no DB) -----------
VECTOR_STORE=pgvector

# --- Queue / ingest path ------------------------------------------------------
#   inproc → no external broker; backend calls AI /ingest directly (simplest)
#   redis  → Redis Streams worker (Upstash) — backpressure for bursty ingest
#   kafka  → durable, retained question log; AI service REPLAYS it on restart to
#            rebuild clusters (event sourcing). See KAFKA.md. Needs the kafka service.
QUEUE_MODE=inproc
REDIS_URL=redis://redis:6379

# Kafka (only used when QUEUE_MODE=kafka). docker-compose sets this to kafka:9092.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_QUESTIONS_TOPIC=questions.incoming

# --- Clustering ---------------------------------------------------------------
# Cosine-similarity threshold to fold a question into an existing cluster.
CLUSTER_SIMILARITY_THRESHOLD=0.78

# --- Service wiring -----------------------------------------------------------
AI_SERVICE_URL=http://ai-service:8000
JWT_SECRET=change-me-to-a-long-random-string-in-prod
